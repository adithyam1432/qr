{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Private user information including PII.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The Firebase Auth UID." },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "insuranceProvider": { "type": "string" },
        "insurancePolicyNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email"]
    },
    "EmergencyProfile": {
      "title": "Emergency Profile",
      "description": "Publicly accessible critical medical information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The linked User UID." },
        "bloodType": { "type": "string", "enum": ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-", "Unknown"] },
        "allergies": { "type": "array", "items": { "type": "string" } },
        "medications": { "type": "array", "items": { "type": "string" } },
        "medicalHistory": { "type": "string" },
        "emergencyContacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "relationship": { "type": "string" },
              "phone": { "type": "string" }
            },
            "required": ["name", "phone"]
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "bloodType"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Private user profiles."
    },
    "/emergency_profiles/{uid}": {
      "schema": "EmergencyProfile",
      "description": "Publicly accessible emergency medical data."
    }
  }
}
